# Copy to .env and fill in. Settings are loaded via pydantic-settings (NFR-6).

# YouTube Data API v3 key — public playlists/videos only need this, no OAuth.
# Get one at https://console.cloud.google.com/ → enable "YouTube Data API v3".
YOUTUBE_API_KEY=

# Phase 3 (AI) — Anthropic API key for transcript summary / study notes.
# Without it, the AI buttons just show a friendly "set the key" message.
# Get one at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=

# Optional: override the SQLite location (single-file DB).
# DATABASE_URL=sqlite:///learnhub.db
